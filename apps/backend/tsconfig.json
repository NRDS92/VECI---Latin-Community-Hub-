{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,

    "rootDir": "./src",
    "outDir": "../../dist",

    "lib": ["ES2022"],
    "types": ["node"],

    "typeRoots": [
      "../../node_modules/@types",
      "./types"
    ]
  },

  "include": ["src"]
}